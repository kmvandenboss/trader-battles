# Trader Battles — environment variables
#
# Copy to .env.local. ALL variables are optional: with none set, the app
# serves the deterministic in-memory demo seed with zero external services
# and no sign-in (the demo / Vercel-preview default).

# Neon Postgres — POOLED connection string ("Pooled connection" in the Neon
# dashboard, host contains "-pooler"). Used by the app at runtime and by
# `npm run db:seed`. When set, getRepositories() serves data from Postgres.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Neon Postgres — DIRECT (unpooled) connection string. Preferred by
# drizzle-kit for `npm run db:migrate` / `db:push` (DDL should not run
# through the pooler). Falls back to DATABASE_URL when unset.
# DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require

# Auth.js (bridge auth) token-signing secret. Required whenever DATABASE_URL
# is set (sign-in/sign-up are DB-backed; without DATABASE_URL there is no
# auth and this can stay unset). Generate one with:
#   npx auth secret        (writes AUTH_SECRET to .env.local)
#   openssl rand -base64 32
# AUTH_SECRET=
